# Deepseek 在线模型 API 的配置
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 阿里云百炼（替代原 GPT-4o）：视觉/图片解析模型
VISION_API_KEY=sk-xxxx
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-max

# 通过 Ollama 本地部署的模型
OLLAMA_BASE_URL=http://localhost:11434  # 注意：这里需要根据实际情况修改

OLLAMA_CHAT_MODEL=qwen2.5:32b   # 聊天模型
OLLAMA_REASON_MODEL=deepseek-r1:32b  # 推理模型
OLLAMA_AGENT_MODEL=qwen2.5:32b  # Agent模型
OLLAMA_EMBEDDING_MODEL=bge-m3  # 词向量模型

# 模型服务选择
CHAT_SERVICE=deepseek  # 或 ollama， 选择哪个模型服务，就会加载对应哪个模型的 API Key，Base URL，Model 等配置
REASON_SERVICE=deepseek  # 或 ollama，如果选择 Deepseek 模型服务，则需要将 DEEPSEEK_MODEL 设置为 deepseek-reason
AGENT_SERVICE=deepseek  # 或 ollama

# SerpAPI配置, 联网搜索的 API，注册地址：https://serpapi.com/
SERPAPI_KEY=xxxx
SEARCH_RESULT_COUNT=3   # 联网搜索结果的数量

# 本地Mysql数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=xxxx
DB_NAME=assist_gen

# 本地Neo4j数据库配置
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=xxxx
NEO4J_DATABASE=neo4j

# 本地Redis缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=xxxx
REDIS_CACHE_EXPIRE=10800
REDIS_CACHE_THRESHOLD=0.90  # 缓存阈值

# Microsoft GraphRAG 配置
GRAPHRAG_PROJECT_DIR=./app/graphrag  # GraphRAG项目目录
GRAPHRAG_DATA_DIR=data                         # 数据目录名称
GRAPHRAG_QUERY_TYPE=local                      # 查询类型: local, global, drift, basic
GRAPHRAG_RESPONSE_TYPE=text                    # 响应类型: text
GRAPHRAG_COMMUNITY_LEVEL=3                     # 社区级别
GRAPHRAG_DYNAMIC_COMMUNITY=false               # 是否动态选择社区

# -----------------------------
# GRAPH_RAG 模型映射配置
# -----------------------------
# 1. GraphRAG 的文本大模型
GRAPHRAG_API_KEY=sk-xxxx
GRAPHRAG_API_BASE=https://api.deepseek.com
GRAPHRAG_MODEL_NAME=deepseek-chat

# 2. GraphRAG 的 Embedding 词向量模型
Embedding_API_KEY=sk-xxxx
Embedding_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
Embedding_MODEL_NAME=text-embedding-v3

# RabbitMQ 配置
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
